a<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>O Código do Silêncio — Dr. Bruno Goulart</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bege:#F2EDE4;--bege2:#E8E0D4;--roxo:#4B0082;--roxo-light:#6B2FA0;--roxo-pale:#C4A8E8;--preto:#0A0A0A;--muted:#6B6560;--text:#1A1A1A}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bege);color:var(--text);overflow-x:hidden}
a{text-decoration:none;color:inherit}

nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:18px 5%;display:flex;justify-content:space-between;align-items:center;background:rgba(242,237,228,.92);backdrop-filter:blur(12px);border-bottom:1px solid rgba(0,0,0,.06)}
.nav-logo{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;color:var(--preto)}
.nav-logo span{color:var(--roxo)}
.nav-back{font-size:13px;color:var(--muted);transition:color .2s}
.nav-back:hover{color:var(--roxo)}

/* HERO */
.hero{min-height:100vh;background:var(--preto);display:flex;align-items:center;padding:120px 8% 80px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 80% 50%,rgba(75,0,130,.15) 0%,transparent 70%)}
.hero-inner{max-width:780px;position:relative;z-index:2}
.hero-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(75,0,130,.25);border:1px solid rgba(75,0,130,.4);color:var(--roxo-pale);font-size:11px;font-weight:500;padding:6px 16px;border-radius:50px;letter-spacing:.1em;text-transform:uppercase;margin-bottom:28px}
.hero-tag::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--roxo-pale)}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(44px,7vw,88px);font-weight:900;color:#fff;line-height:1.05;margin-bottom:28px;letter-spacing:-.02em}
.hero h1 em{font-style:italic;color:var(--roxo-pale)}
.hero-desc{font-size:19px;color:rgba(255,255,255,.55);line-height:1.8;max-width:580px;margin-bottom:16px;font-weight:300}
.hero-promise{font-size:16px;color:rgba(255,255,255,.35);line-height:1.7;max-width:560px;margin-bottom:52px;font-weight:300;font-style:italic;border-left:2px solid var(--roxo);padding-left:20px}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;align-items:center}
.btn-primary{background:var(--roxo);color:#fff;padding:18px 44px;border-radius:50px;font-size:15px;font-weight:500;letter-spacing:.04em;transition:all .2s;display:inline-block}
.btn-primary:hover{background:var(--roxo-light);transform:translateY(-2px)}
.hero-price{font-size:15px;color:rgba(255,255,255,.35)}
.hero-price strong{color:rgba(255,255,255,.7);font-size:18px}

/* PARA QUEM */
.forwho{padding:100px 8%;background:var(--bege2)}
.eyebrow{font-size:11px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--roxo);margin-bottom:16px}
.h2{font-family:'Playfair Display',serif;font-size:clamp(30px,4vw,50px);font-weight:700;color:var(--preto);line-height:1.15;margin-bottom:48px}
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px}
.card{background:#fff;border-radius:20px;padding:28px 24px;border:1px solid rgba(0,0,0,.06)}
.card-icon{font-size:26px;margin-bottom:14px}
.card h3{font-size:15px;font-weight:600;color:var(--preto);margin-bottom:8px}
.card p{font-size:14px;color:var(--muted);line-height:1.65;font-weight:300}

/* O QUE VOCÊ VAI APRENDER */
.aprenda{padding:100px 8%;background:var(--preto)}
.aprenda-eyebrow{font-size:11px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--roxo-pale);margin-bottom:16px}
.aprenda-h2{font-family:'Playfair Display',serif;font-size:clamp(30px,4vw,50px);font-weight:700;color:#fff;line-height:1.15;margin-bottom:56px}
.blocos{display:flex;flex-direction:column;gap:0}
.bloco{display:flex;gap:32px;padding:36px 0;border-bottom:1px solid rgba(255,255,255,.07);align-items:flex-start}
.bloco:last-child{border-bottom:none}
.bloco-num{font-family:'Playfair Display',serif;font-size:52px;font-weight:900;color:var(--roxo-pale);flex-shrink:0;width:64px;line-height:1}
.bloco-content h3{font-size:20px;font-weight:600;color:#fff;margin-bottom:10px;letter-spacing:.01em}
.bloco-content p{font-size:15px;color:rgba(255,255,255,.65);line-height:1.75;font-weight:300}
.bloco-tag{display:inline-block;background:rgba(75,0,130,.3);color:var(--roxo-pale);font-size:10px;font-weight:500;padding:3px 12px;border-radius:20px;letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px}

/* SOBRE O MÉDICO */
.sobre{padding:100px 8%;background:var(--bege);display:grid;grid-template-columns:280px 1fr;gap:72px;align-items:center}
.sobre-foto{border-radius:20px;overflow:hidden;aspect-ratio:3/4}
.sobre-foto img{width:100%;height:100%;object-fit:cover;object-position:center top;filter:grayscale(20%)}
.sobre-eyebrow{font-size:11px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--roxo);margin-bottom:16px}
.sobre h2{font-family:'Playfair Display',serif;font-size:clamp(28px,3.5vw,44px);font-weight:700;color:var(--preto);line-height:1.15;margin-bottom:20px}
.sobre p{font-size:16px;color:var(--muted);line-height:1.85;margin-bottom:18px;font-weight:300}

/* CTA */
.cta{padding:100px 8%;background:linear-gradient(135deg,var(--roxo) 0%,#1E0040 100%);text-align:center;position:relative;overflow:hidden}
.cta-inner{max-width:560px;margin:0 auto;position:relative;z-index:2}
.cta-eyebrow{font-size:11px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--roxo-pale);margin-bottom:16px}
.cta h2{font-family:'Playfair Display',serif;font-size:clamp(32px,4vw,52px);font-weight:700;color:#fff;line-height:1.15;margin-bottom:12px}
.cta p{font-size:16px;color:rgba(255,255,255,.55);margin-bottom:48px;font-weight:300;line-height:1.7}
.price-block{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:24px;padding:40px 56px;margin-bottom:36px;display:inline-block}
.price-de{font-size:18px;color:rgba(255,255,255,.35);text-decoration:line-through;margin-bottom:6px}
.price-por{font-size:14px;color:rgba(255,255,255,.5);letter-spacing:.1em;text-transform:uppercase;margin-bottom:10px}
.price-num{font-family:'Playfair Display',serif;font-size:clamp(100px,18vw,160px);font-weight:900;color:#fff;line-height:.9;display:flex;align-items:center;justify-content:center;gap:8px}
.price-rs{font-size:clamp(52px,8vw,72px);font-weight:700;color:var(--roxo-pale);line-height:1}
.price-obs{font-size:15px;color:rgba(255,255,255,.4);margin-top:16px;letter-spacing:.04em}
.btn-cta{display:inline-block;background:#fff;color:var(--roxo);padding:20px 56px;border-radius:50px;font-size:15px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;transition:all .2s;box-shadow:0 8px 32px rgba(0,0,0,.2)}
.btn-cta:hover{background:#f0e8ff;transform:translateY(-2px)}
.guarantee{display:flex;align-items:center;gap:8px;justify-content:center;margin-top:20px;font-size:13px;color:rgba(255,255,255,.4)}

/* FAQ */
.faq{padding:80px 8%;background:var(--bege2)}
.faq-inner{max-width:700px;margin:0 auto}
.faq-inner h2{font-family:'Playfair Display',serif;font-size:36px;font-weight:700;color:var(--preto);margin-bottom:40px}
.faq-item{border-bottom:1px solid rgba(0,0,0,.1)}
.faq-q{padding:20px 0;font-size:15px;font-weight:500;color:var(--preto);cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:12px}
.faq-icon{font-size:20px;color:var(--roxo);transition:transform .25s;flex-shrink:0}
.faq-a{display:none;padding:0 0 20px;font-size:14px;color:var(--muted);line-height:1.75;font-weight:300}
.faq-item.open .faq-a{display:block}
.faq-item.open .faq-icon{transform:rotate(45deg)}

/* FOOTER */
footer{background:var(--preto);padding:40px 8%;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:20px}
.footer-logo{font-family:'Playfair Display',serif;font-size:16px;font-weight:700;color:#fff}
.footer-logo span{color:var(--roxo-pale)}
footer p{font-size:12px;color:rgba(255,255,255,.25)}
.footer-links{display:flex;gap:20px}
.footer-links a{font-size:12px;color:rgba(255,255,255,.35);transition:color .2s}
.footer-links a:hover{color:var(--roxo-pale)}

@media(max-width:768px){
  nav{padding:16px 5%}
  .hero,.forwho,.aprenda,.sobre,.cta,.faq{padding-left:6%;padding-right:6%}
  .hero{padding-top:100px;padding-bottom:60px}
  .sobre{grid-template-columns:1fr;gap:36px}
  .sobre-foto{aspect-ratio:4/3}
  .bloco{gap:20px}
  .bloco-num{font-size:40px;width:48px}
  .hero-btns{flex-direction:column;align-items:flex-start}
  .btn-primary{width:100%;text-align:center}
  .price-block{padding:32px 28px;width:100%}
  footer{flex-direction:column;text-align:center}
  .footer-links{flex-wrap:wrap;justify-content:center}
}
</style>
</head>
<body>

<nav>
  <div class="nav-logo">Dr. <span>Bruno Goulart</span></div>
  <a href="/" class="nav-back">← Voltar ao site</a>
