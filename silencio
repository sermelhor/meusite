    <a href="https://instagram.com/drbrunogoulart" target="_blank">Instagram</a>
  </div>
</footer>

<script>
function toggleFaq(el){const item=el.parentElement;const open=item.classList.contains('open');document.querySelectorAll('.faq-item.open').forEach(i=>i.classList.remove('open'));if(!open)item.classList.add('open');}
</script>
</body>
</html>

